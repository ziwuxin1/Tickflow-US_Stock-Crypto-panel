# ===== TickFlow(美股数据源) =====
# 留空或不填则启用 None 模式(free-api 服务器),仅能拉美股历史日 K(如 AAPL.US)
# 填入有效 Key 则按订阅档位解锁实时行情等能力
TICKFLOW_API_KEY=

# 美股数据源切换: tickflow(默认) | yfinance
#   tickflow  — 免 key 有全市场历史日 K, 适合全市场选股扫描
#   yfinance  — Yahoo 免费源, 近实时报价 + 更即时日 K, 适合按需看图/自选;
#               大批量(全市场)会被 Yahoo 限流, 不建议开着跑盘后全市场管道
US_DATA_SOURCE=tickflow

# ===== 加密货币(Binance 公共行情,免 key) =====
# 加密行情走 Binance 公共端点,无需注册/API Key。
# 默认 data-api.binance.vision(api.binance.com 在部分地区被屏蔽)。
CRYPTO_API_BASE=https://data-api.binance.vision
# 加密标的池大小:按 24h 成交额取前 N 个 USDT 现货交易对
CRYPTO_UNIVERSE_SIZE=300

# CoinGecko(加密市值/流通量/排名,补 Binance 没有的维度;免 key 可用)
# 给加密 instruments 填流通量 → 市值筛选、换手率对加密也生效。
COINGECKO_API_BASE=https://api.coingecko.com/api/v3
COINGECKO_API_KEY=          # 留空=公共档(~30次/分);可填 Demo/Pro key 提额

# ===== AI(可选,留空跳过 AI 功能) =====
AI_PROVIDER=openai_compat          # openai_compat | ollama
AI_BASE_URL=https://api.deepseek.com/v1
AI_API_KEY=
AI_MODEL=deepseek-chat
AI_DAILY_TOKEN_BUDGET=500000

# ===== Server =====
HOST=0.0.0.0
PORT=3018
LOG_LEVEL=INFO

# ===== Auth =====
# 首次启动时预置访问密码(可选)。公网服务器部署时填入,免去 SSH 端口转发设密码。
# 仅在尚未设置密码时生效(一次性初始化);设过后改密码请用页面 UI, 此处不再读取。
# 建议至少 6 位。.env 文件权限保持 600 且不要提交到 Git。
AUTH_PASSWORD=

# Optional Docker build extras. Set to legacy-cpu on older VPS hosts
# without AVX2/FMA support.
BACKEND_EXTRAS=

# ===== Data =====
DATA_DIR=./data
